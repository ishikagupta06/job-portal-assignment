# MongoDB Connection
# For Atlas: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jobportal
# For local: mongodb://localhost:27017/jobportal
MONGODB_URI=mongodb://localhost:27017/jobportal

# JWT (use a strong secret in production)
JWT_SECRET=your-secret-key-change-in-production

# API URL for frontend (optional - defaults to http://localhost:5000/api)
# VITE_API_URL=http://localhost:5000/api
